{
  "servers": {
    "pac-cli": {
      "type": "stdio",
      "command": "pac",
      "args": ["copilot", "mcp", "--run"]
    },
    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "D:\\my agents copilot studio"]
    },
    "git": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-git", "D:\\my agents copilot studio"]
    },
    "github": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"]
    },
    "learn-docs": {
      "type": "http",
      "url": "https://learn.microsoft.com/api/mcp"
    },
    "azure-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@azure/mcp@latest", "server", "start", "--mode", "consolidated"]
    },
    "powerbi-remote": {
      "type": "http",
      "url": "https://api.fabric.microsoft.com/v1/mcp/powerbi"
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--headed",
        "--browser",
        "msedge",
        "--output-dir",
        "D:\\my agents copilot studio\\.playwright-mcp",
        "--user-data-dir",
        "C:\\Users\\kevin\\AppData\\Local\\Microsoft\\Edge\\User Data",
        "--save-session",
        "--timeout-navigation",
        "90000",
        "--timeout-action",
        "10000"
      ]
    }
  }
}
