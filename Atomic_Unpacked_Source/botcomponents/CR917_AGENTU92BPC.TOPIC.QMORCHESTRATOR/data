mcs.metadata:
  componentName: QM Orchestrator
  description: Primary entry point and router for all QM workflows. Routes user requests to the appropriate sub-topic based on intent detection, facility context, and uploaded data.
kind: AdaptiveDialog
beginDialog:
  kind: OnRecognizedIntent
  id: main
  intent: {}
  actions:
    - kind: Question
      id: question_V6zkac
      interruptionPolicy:
        allowInterruption: true
      variable: init:Topic.routeChoice
      prompt: Choose a QM workflow to continue.
      entity:
        kind: EmbeddedEntity
        definition:
          kind: ClosedListEntity
          items:
            - id: Facility QM Review
              displayName: Facility QM Review

            - id: QM Driver Analysis
              displayName: QM Driver Analysis

            - id: Resident Outlier Analysis
              displayName: Resident Outlier Analysis

            - id: QM Decline Detection
              displayName: QM Decline Detection

            - id: QM Action Plan
              displayName: QM Action Plan

            - id: DoR Summary Email
              displayName: DoR Summary Email

            - id: QM Intake
              displayName: QM Intake

    - kind: ConditionGroup
      id: conditionGroup_imoZbs
      conditions:
        - id: conditionItem_du1Pbq
          condition: =true
          actions:
            - kind: BeginDialog
              id: beginDialog_FacilityQM
              dialog: cr917_agentu92bPc.topic.FacilityQMAnalysis

        - id: conditionItem_GnZ8zv
          condition: =true
          actions:
            - kind: BeginDialog
              id: beginDialog_QMDrivers
              dialog: cr917_agentu92bPc.topic.QMDriverAnalysis

        - id: conditionItem_7qkYQo
          condition: =true
          actions:
            - kind: BeginDialog
              id: beginDialog_ResidentOutlier
              dialog: cr917_agentu92bPc.topic.ResidentOutlierAnalysis

        - id: conditionItem_7g7Fbw
          condition: =true
          actions:
            - kind: BeginDialog
              id: beginDialog_DeclineDetection
              dialog: cr917_agentu92bPc.topic.QMDataUploadDeclineDetection

        - id: conditionItem_GXwrUu
          condition: =true
          actions:
            - kind: BeginDialog
              id: beginDialog_ActionPlan
              dialog: cr917_agentu92bPc.topic.QMActionPlan

        - id: conditionItem_irYU4n
          condition: =true
          actions:
            - kind: BeginDialog
              id: beginDialog_DoRSummary
              dialog: cr917_agentu92bPc.topic.DoRSummary

        - id: conditionItem_I1YmEg
          condition: =true
          actions:
            - kind: BeginDialog
              id: beginDialog_QMIntake
              dialog: cr917_agentu92bPc.topic.QMIntake

      elseActions:
        - kind: SendActivity
          id: sendActivity_invalidChoice
          activity: I didn't recognize that choice. Please select one of the available QM workflows.

inputType: {}
outputType:
  properties:
    ProcessingStatus:
      type: String
      title: ProcessingStatus



