{
  "type": "AdaptiveCard",
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "version": "1.4",
  "backgroundImage": {
    "url": "https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&q=80&w=1000"
  },
  "body": [
    {
      "type": "TextBlock",
      "text": "SNF DASHBOARD | EXECUTIVE KPI SNAPSHOT",
      "color": "Accent",
      "weight": "Bolder",
      "size": "Small"
    },
    {
      "type": "ColumnSet",
      "columns": [
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            { "type": "TextBlock", "text": "Clinical Urgency", "size": "Small", "isSubtle": true },
            { "type": "TextBlock", "text": "${avgUrgency}%", "size": "ExtraLarge", "weight": "Bolder", "color": "Attention" }
          ]
        },
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            { "type": "TextBlock", "text": "QM Compliance", "size": "Small", "isSubtle": true },
            { "type": "TextBlock", "text": "${qmHealth}%", "size": "ExtraLarge", "weight": "Bolder", "color": "Good" }
          ]
        }
      ]
    },
    {
      "type": "TextBlock",
      "text": "**Outlier Alert:** ${topOutlier} is currently 15% above target thresholds.",
      "wrap": true,
      "color": "Warning"
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "📊 Launch Full Analytics",
      "style": "positive"
    }
  ]
}
