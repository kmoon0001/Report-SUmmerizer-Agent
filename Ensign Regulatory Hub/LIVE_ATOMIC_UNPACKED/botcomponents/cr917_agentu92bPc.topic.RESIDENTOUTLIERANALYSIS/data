mcs.metadata:
  componentName: Resident Outlier Analysis
  description: Collects resident-outlier analysis context for secure workflow execution and coaching recommendations while enforcing HIPAA minimum necessary compliance.
kind: AdaptiveDialog
beginDialog:
  kind: OnRecognizedIntent
  id: main
  intent: {}
  actions:
    - kind: ConditionGroup
      id: conditionGroup_outlierContext
      conditions:
        - id: conditionItem_hasGlobalFacilityOutlier
          condition: =!IsBlank(Global.SelectedFacility)
          actions:
            - kind: SetVariable
              id: setVariable_syncOutlierFacility
              variable: Topic.selectedFacility
              value: =Global.SelectedFacility

      elseActions:
        - kind: Question
          id: question_tODM2n
          interruptionPolicy:
            allowInterruption: true

          variable: init:Topic.selectedFacility
          prompt: Which facility should this resident outlier review use?
          entity: StringPrebuiltEntity

    - kind: Question
      id: question_oLugIE
      interruptionPolicy:
        allowInterruption: true

      variable: init:Topic.coachingOutput
      prompt: "What coaching output do you want first: intervention ideas, documentation checkpoints, or escalation triggers?"
      entity: StringPrebuiltEntity

    - kind: Question
      id: question_vOiqE9
      interruptionPolicy:
        allowInterruption: true

      variable: init:Topic.outlierPattern
      prompt: Which resident outlier pattern should we analyze first?
      entity:
        kind: EmbeddedEntity
        definition:
          kind: ClosedListEntity
          items:
            - id: Repeated QM trigger
              displayName: Repeated QM trigger

            - id: Multi-QM trigger
              displayName: Multi-QM trigger

            - id: Functional decline
              displayName: Functional decline

            - id: Post-hospital return
              displayName: Post-hospital return

            - id: New admission risk
              displayName: New admission risk

            - id: Documentation checkpoints
              displayName: Documentation checkpoints

            - id: Escalation triggers
              displayName: Escalation triggers

        displayName: EmbeddedEntity-1l5CgD

    - kind: ConditionGroup
      id: conditionGroup_MuLWQT
      conditions:
        - id: conditionItem_BxXlSy
          condition: =Topic.outlierPattern = 'Multi-QM trigger'

        - id: conditionItem_2c2iAG
          condition: =Topic.outlierPattern = 'Functional decline'

        - id: conditionItem_aaPKuW
          condition: =Topic.outlierPattern = 'Post-hospital return'

        - id: conditionItem_6dNO3K
          condition: =Topic.outlierPattern = 'New admission risk'

        - id: conditionItem_PMsuPA
          condition: =Topic.outlierPattern = 'Documentation checkpoints'

        - id: conditionItem_9TrmWg
          condition: =Topic.outlierPattern = 'Escalation triggers'

    - kind: InvokeFlowAction
      id: invokeFlowAction_sItQNY
      input: {}
      output:
        binding:
          resident_data_text: Topic.resident_data_text

      flowId: 88ce03b7-6b25-f111-8341-000d3a33801d

    - kind: ConditionGroup
      id: conditionGroup_checkFlowResult
      conditions:
        - id: conditionItem_emptyResult
          condition: =IsBlank(Topic.resident_data_text)
          actions:
            - kind: SendActivity
              id: sendActivity_FlowFailed
              activity: I was unable to retrieve the resident outlier data. The backend service may be unavailable. Please try again.
            - kind: EndDialog
              id: endDialog_FlowFailed
      elseActions:
        - kind: SendActivity
          id: sendActivity_FlowSuccess
          activity: ="Here is the resident anomaly review based on your request:\n\n" & Topic.resident_data_text

inputType: {}
outputType: {}
