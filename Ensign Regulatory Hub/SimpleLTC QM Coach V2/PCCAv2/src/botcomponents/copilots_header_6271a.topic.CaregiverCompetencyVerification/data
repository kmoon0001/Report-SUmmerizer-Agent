mcs.metadata:
  componentName: Caregiver Competency Verification
kind: AdaptiveDialog
beginDialog:
  kind: OnRecognizedIntent
  id: main
  intent:
    displayName:
    triggerQueries:
      - caregiver competency verification
      - verify caregiver skills
      - check caregiver qualifications
      - caregiver assessment
      - confirm caregiver competency
      - evaluate caregiver abilities
      - caregiver skill check
      - competency test for caregivers
      - how to verify a caregiver's competency
      - caregiver certification process

  actions:
    - kind: SearchAndSummarizeContent
      id: caregiver_competency_audit
      userInput: =System.Activity.Text
      additionalInstructions: |-
        Analyze the provided caregiver competency text as a backend connected agent. Return exactly one valid JSON object using the SLP_Specialist schema. Do not ask follow-up questions or emit narrative. If evidence is incomplete, return a JSON error object that lists missing competency evidence or training gaps.
      fileSearchDataSource:
        searchFilesMode:
          kind: SearchSpecificFiles
          files:
            - copilots_header_6271a.file.Ch15MedicareBenefitsPolicyManual.pdf_fv6
