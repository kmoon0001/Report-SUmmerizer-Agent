  componentName: Reset Conversation
  description: Clears all conversation state and variables, cancels active dialogs, and returns the user to a clean starting point.
kind: AdaptiveDialog
startBehavior: UseLatestPublishedContentAndCancelOtherTopics
beginDialog:
  kind: OnSystemRedirect
  id: main
  actions:
