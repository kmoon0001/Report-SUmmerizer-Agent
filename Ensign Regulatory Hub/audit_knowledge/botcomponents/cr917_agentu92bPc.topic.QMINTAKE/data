kind: AdaptiveDialog
beginDialog:
  kind: OnRecognizedIntent
  id: main
  intent: {}
  actions:
    - kind: Question
      id: question_LRSzQ7
      interruptionPolicy:
        allowInterruption: true

      variable: init:Topic.selectedFacility
      prompt: Which facility are we reviewing?
      entity: StringPrebuiltEntity

    - kind: Question
      id: question_EJ8okf
      interruptionPolicy:
        allowInterruption: true

      variable: init:Topic.lookbackPeriod
      prompt: What lookback period should we use (30 days, 60 days, 90 days, or current quarter)?
      entity: StringPrebuiltEntity

    - kind: ConditionGroup
      id: conditionGroup_hVNZde
      conditions:
        - id: conditionItem_eVtbFG
          condition: =Topic.lookbackPeriod = "Last 60 days"
          actions:
            - kind: SendActivity
              id: sa1
              activity: 60 days selected.

      elseActions:
        - kind: SendActivity
          id: sa2
          activity: Default lookback selected.

    - kind: Question
      id: question_LpmWm6
      interruptionPolicy:
        allowInterruption: true

      variable: init:Topic.qmDomain
      prompt: Which QM domain should we focus on?
      entity: StringPrebuiltEntity

    - kind: SendActivity
      id: sa3
      activity: Intake complete. Moving to orchestrator.

    - kind: BeginDialog
      id: MVvnKE
      dialog: cr917_agentu92bPc.topic.QMOrchestrator

inputType: {}
outputType: {}
mcs.metadata:
  componentName: QM Intake
  description: Collects required QM intake context (facility, lookback period, QM domain) and prepares a concise intake summary.