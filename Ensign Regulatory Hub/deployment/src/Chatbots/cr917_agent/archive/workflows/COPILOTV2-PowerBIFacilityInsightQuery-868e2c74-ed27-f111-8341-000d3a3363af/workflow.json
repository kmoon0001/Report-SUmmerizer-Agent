        "Run_a_query_against_a_dataset_1": {
          "type": "OpenApiConnection",
          "inputs": {
            "parameters": {
              "groupid": "0b0fa563-4e46-4bbe-93de-a6b4d4711fc4",
              "datasetid": "aedcbfa3-52c6-4ccf-ac1d-0d54c042f9b3",
              "specification/query": "test queryEVALUATE     TOPN(     25,     ADDCOLUMNS(     SUMMARIZECOLUMNS(     \u0027Entity\u0027[Facility],     \u0027Patient\u0027[Patient Full Name],     \u0027Patient\u0027[Patient ID],     FILTER(\u0027Patient\u0027, \u0027Patient\u0027[is_active] = TRUE()),     \u0022adl_score\u0022, MAX(\u0027fact_therapy_outcomes\u0027[adl_score]),     \u0022braden\u0022, MAX(\u0027fact_therapy_outcomes\u0027[braden]),     \u0022bims\u0022, MAX(\u0027fact_therapy_outcomes\u0027[bims]),     \u0022falls_risk\u0022, MAX(\u0027fact_therapy_outcomes\u0027[falls_risk]),     \u0022total_falls\u0022, MAX(\u0027fact_therapy_outcomes\u0027[total_falls]),     \u0022total_injuries\u0022, MAX(\u0027fact_therapy_outcomes\u0027[total_injuries]),     \u0022new_skin_injury\u0022, MAX(\u0027fact_therapy_outcomes\u0027[new_skin_injury]),     \u0022total_behaviors\u0022, MAX(\u0027fact_therapy_outcomes\u0027[total_behaviors]),     \u0022antipsychotic\u0022, MAX(\u0027fact_therapy_outcomes\u0027[antipsychotic]),     \u0022had_fall_30_days\u0022, MAX(\u0027fact_therapy_outcomes\u0027[had_fall_30_days]),     \u0022had_injury_30_days\u0022, MAX(\u0027fact_therapy_outcomes\u0027[had_injury_30_days]),     \u0022had_skin_injury_30_days\u0022, MAX(\u0027fact_therapy_outcomes\u0027[had_skin_injury_30_days]),     \u0022had_behavior_30_days\u0022, MAX(\u0027fact_therapy_outcomes\u0027[had_behavior_30_days]),     \u0022had_antipsychotic_30_days\u0022, MAX(\u0027fact_therapy_outcomes\u0027[had_antipsychotic_30_days])     ),     \u0022outlier_score\u0022,     COALESCE([had_fall_30_days], 0) * 10 \u002B     COALESCE([had_injury_30_days], 0) * 12 \u002B     COALESCE([had_skin_injury_30_days], 0) * 9 \u002B     COALESCE([had_behavior_30_days], 0) * 6 \u002B     COALESCE([had_antipsychotic_30_days], 0) * 6 \u002B     COALESCE([total_falls], 0) * 4 \u002B     COALESCE([total_injuries], 0) * 5 \u002B     COALESCE([new_skin_injury], 0) * 5 \u002B     COALESCE([total_behaviors], 0) * 3 \u002B     COALESCE([antipsychotic], 0) * 3     ),     [outlier_score], DESC,     [total_falls], DESC,     [total_injuries], DESC,     \u0027Patient\u0027[Patient Full Name], ASC     )",
              "specification/serializerSettings/includeNulls": false
            },
