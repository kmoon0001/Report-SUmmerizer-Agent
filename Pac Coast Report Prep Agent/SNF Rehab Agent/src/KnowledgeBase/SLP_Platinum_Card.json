{
  "type": "AdaptiveCard",
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "version": "1.4",
  "backgroundImage": {
    "url": "https://images.unsplash.com/photo-1559757175-5700dde675bc?auto=format&fit=crop&q=80&w=1000"
  },
  "body": [
    {
      "type": "TextBlock",
      "text": "SLP PORTAL | CLINICAL REFINER",
      "color": "Accent",
      "weight": "Bolder",
      "size": "Small"
    },
    {
      "type": "TextBlock",
      "text": "SLP Note Review: Dysphagia & Cognition",
      "weight": "Bolder",
      "size": "ExtraLarge"
    },
    {
      "type": "Input.Text",
      "id": "slpNarrative",
      "label": "SLP Summary (Editable):",
      "isMultiline": true,
      "value": "${slpGeneratedText}"
    },
    {
      "type": "Input.ChoiceSet",
      "id": "dietConsistency",
      "label": "Recommended Diet:",
      "choices": [
        { "title": "Regular / Thin", "value": "thin" },
        { "title": "Mechanical Soft / Mildly Thick", "value": "thick" },
        { "title": "Pureed / Extremely Thick", "value": "puree" }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "💾 Sync to SLP EHR Queue",
      "style": "positive"
    }
  ]
}
