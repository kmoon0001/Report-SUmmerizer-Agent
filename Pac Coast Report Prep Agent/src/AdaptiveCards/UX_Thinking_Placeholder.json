{
  "type": "AdaptiveCard",
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "version": "1.4",
  "body": [
    {
      "type": "ColumnSet",
      "columns": [
        {
          "type": "Column",
          "width": "auto",
          "items": [
            {
              "type": "Image",
              "url": "https://media.giphy.com/media/v1.Y2lkPTc5MGI3NjExNHJqNGp4Z3R4Z3R4Z3R4Z3R4Z3R4Z3R4Z3R4Z3R4Z3R4/3oEjI6SIIHBdRxXI40/giphy.gif",
              "size": "Small"
            }
          ]
        },
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "TextBlock",
              "text": "⚙️ Clinical Engine Processing...",
              "weight": "Bolder",
              "size": "Medium"
            },
            {
              "type": "TextBlock",
              "text": "Analyzing record **${recordId}** against CMS Step-by-Step guidelines. Please hold while I generate your briefing...",
              "wrap": true,
              "isSubtle": true
            }
          ]
        }
      ]
    }
  ]
}
