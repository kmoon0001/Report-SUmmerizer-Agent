{
  "properties": {
    "connectionReferences": {
      "shared_commondataserviceforapps": {
        "api": { "name": "shared_commondataserviceforapps" },
        "connection": { "connectionReferenceLogicalName": "new_sharedcommondataserviceforapps_af899" },
        "runtimeSource": "embedded"
      },
      "shared_office365": {
        "api": { "name": "shared_office365" },
        "connection": { "connectionReferenceLogicalName": "new_sharedoffice365_Pacific_Coast" },
        "runtimeSource": "embedded"
      }
    },
    "definition": {
      "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
      "contentVersion": "1.0.0.0",
      "description": "Pacific Coast Clinical Synthesis Lab — Email SBAR Report Flow. Delivers structured clinical briefs (Recert, Eval, Progress, Discharge) to facility leadership via email. Adheres to HIPAA secure transmission standards.",
      "parameters": {
        "$authentication": { "defaultValue": {}, "type": "SecureObject" },
        "$connections": { "defaultValue": {}, "type": "Object" }
      },
      "triggers": {
        "manual": {
          "type": "Request",
          "kind": "Skills",
          "inputs": {
            "schema": {
              "type": "object",
              "properties": {
                "text": {
                  "description": "The SBAR brief content",
                  "title": "SBARContent",
                  "type": "string",
                  "x-ms-content-hint": "TEXT",
                  "x-ms-dynamically-added": true
                },
                "text_1": {
                  "description": "Patient name or alias",
                  "title": "PatientName",
                  "type": "string",
                  "x-ms-content-hint": "TEXT",
                  "x-ms-dynamically-added": true
                },
                "text_2": {
                  "description": "Report category (Recert, Eval, etc.)",
                  "title": "ReportCategory",
                  "type": "string",
                  "x-ms-content-hint": "TEXT",
                  "x-ms-dynamically-added": true
                },
                "text_3": {
                  "description": "Facility name",
                  "title": "FacilityName",
                  "type": "string",
                  "x-ms-content-hint": "TEXT",
                  "x-ms-dynamically-added": true
                }
              },
              "required": ["text", "text_1", "text_2", "text_3"]
            }
          },
          "metadata": {
            "operationMetadataId": "email-sbar-trigger-v1"
          }
        }
      },
      "actions": {
        "Send_SBAR_Email": {
          "type": "OpenApiConnection",
          "inputs": {
            "parameters": {
              "emailMessage/To": "leadership@pacificcoast.com",
              "emailMessage/Subject": "@{concat('[Clinical Synthesis Lab] ', triggerBody()?['text_2'], ' Brief — ', triggerBody()?['text_1'], ' — ', triggerBody()?['text_3'])}",
              "emailMessage/Body": "@{concat('<h1 style=\"color:#2c5f8a\">🔬 Pacific Coast Clinical Synthesis Brief</h1><h2>', triggerBody()?['text_2'], ' Analysis</h2><p><strong>Patient:</strong> ', triggerBody()?['text_1'], ' | <strong>Facility:</strong> ', triggerBody()?['text_3'], '</p><hr/><div style=\"font-family:Arial;font-size:14px;white-space:pre-wrap\">', triggerBody()?['text'], '</div><hr/><p><em>Generated by Pacific Coast Clinical Synthesis Lab. Adheres to CMS Chapter 15 and professional clinical standards.</em></p>')}"
            },
            "host": {
              "apiId": "/providers/Microsoft.PowerApps/apis/shared_office365",
              "operationId": "SendEmailV2",
              "connectionName": "shared_office365"
            }
          },
          "runAfter": {}
        },
        "Respond_to_the_agent": {
          "type": "Response",
          "kind": "Skills",
          "inputs": {
            "schema": {
              "type": "object",
              "properties": {
                "status": {
                  "title": "Status",
                  "description": "Email delivery status",
                  "type": "string",
                  "x-ms-content-hint": "TEXT",
                  "x-ms-dynamically-added": true
                }
              },
              "additionalProperties": {}
            },
            "statusCode": 200,
            "body": {
              "status": "SBAR Brief emailed successfully to facility leadership."
            }
          },
          "runAfter": {
            "Send_SBAR_Email": ["SUCCEEDED"]
          }
        }
      },
      "outputs": {}
    }
  },
  "schemaVersion": "1.0.0.0"
}
