{
  "type": "AdaptiveCard",
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "version": "1.4",
  "backgroundImage": {
    "url": "https://images.unsplash.com/photo-1576091160550-21735994b1a3?auto=format&fit=crop&q=80&w=1000",
    "fillMode": "cover",
    "horizontalAlignment": "center"
  },
  "body": [
    {
      "type": "Container",
      "style": "emphasis",
      "bleed": true,
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "Image",
                  "url": "https://upload.wikimedia.org/wikipedia/commons/4/4f/Microsoft_Teams_logo_2019.svg",
                  "size": "Small"
                }
              ]
            },
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "PAC COAST | CLINICAL INTELLIGENCE",
                  "color": "Accent",
                  "weight": "Bolder",
                  "size": "Small",
                  "wrap": true
                },
                {
                  "type": "TextBlock",
                  "text": "Daily Rehab Briefing Approval",
                  "weight": "Bolder",
                  "size": "ExtraLarge",
                  "wrap": true,
                  "spacing": "None"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "spacing": "Large",
      "items": [
        {
          "type": "FactSet",
          "facts": [
            { "title": "🏥 Facility:", "value": "${facilityName}" },
            { "title": "👩‍⚕️ Lead Therapist:", "value": "${therapistName}" },
            { "title": "📅 Briefing Date:", "value": "${briefingDate}" },
            { "title": "⚠️ Compliance Alerts:", "value": "${complianceIssuesFlag}" }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "separator": true,
      "spacing": "Medium",
      "items": [
        {
          "type": "TextBlock",
          "text": "PATIENT ROSTER (SELECT TO BROADCAST)",
          "weight": "Bolder",
          "size": "Medium",
          "color": "Accent"
        },
        {
          "type": "Input.ChoiceSet",
          "id": "approvedPatients",
          "style": "expanded",
          "isMultiSelect": true,
          "wrap": true,
          "choices": [
            {
              "title": "🟢 [${reportType_1}] - ${patientToken_1} (Urgency: ${urgency_1})\n📄 Summary: ${clinicalSummary_1}",
              "value": "${patientToken_1}"
            },
            {
              "title": "🟡 [${reportType_2}] - ${patientToken_2} (Urgency: ${urgency_2})\n📄 Summary: ${clinicalSummary_2}",
              "value": "${patientToken_2}"
            }
          ]
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "🚀 Approve & Notify Team",
      "data": { "actionType": "approveSelected" },
      "style": "positive"
    },
    {
      "type": "Action.OpenUrl",
      "title": "🛠️ Expert Dashboard",
      "url": "https://make.powerapps.com/environments/${envId}/apps/${appId}",
      "iconUrl": "https://upload.wikimedia.org/wikipedia/commons/e/e5/Microsoft_Power_Apps_Icon.svg"
    },
    {
      "type": "Action.Submit",
      "title": "✖️ Reject All",
      "data": { "actionType": "rejectAll" },
      "style": "destructive"
    }
  ]
}
