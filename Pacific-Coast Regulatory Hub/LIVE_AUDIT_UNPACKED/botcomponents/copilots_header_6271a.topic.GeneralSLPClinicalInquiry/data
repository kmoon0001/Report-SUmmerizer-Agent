mcs.metadata:
  componentName: General SLP Clinical Inquiry
kind: AdaptiveDialog
beginDialog:
  kind: OnRecognizedIntent
  id: main
  intent:
    displayName:
    triggerQueries:
      - ask about speech therapy
      - speech language pathology questions
      - general SLP inquiry
      - talk to an SLP
      - speech therapist information
      - how does speech therapy work?
      - what does an SLP do?
      - SLP services available?
      - help with communication issues
      - learn about speech therapy

  actions:
    - kind: SearchAndSummarizeContent
      id: gt7xuR
      latencyMessageSettings:
        allowLatencyMessage: true
        latencyMessage: Please wait while I consult the ASHA guidelines and Medicare Benefit Policy Manual to provide you with the most accurate clinical information...

      userInput: =System.Activity.Text
      additionalInstructions: |-
        Analyze the provided SLP clinical inquiry as a backend connected agent. Return exactly one valid JSON object using the SLP_Specialist schema. Do not ask follow-up questions or emit narrative. If the information is not in the provided evidence, return a JSON error object instead of guessing.
      webBrowsing: false
      fileSearchDataSource:
        searchFilesMode:
          kind: SearchSpecificFiles
          files:
            - copilots_header_6271a.file.Ch15MedicareBenefitsPolicyManual.pdf_fv6
            - copilots_header_6271a.file.ScopeofPracticeinSpeech8-26-09.pdf_6hn
            - copilots_header_6271a.file.dysphagia-competency-verification-tool-users-guide.pdf_sQX
            - copilots_header_6271a.file.CodingforSLPs.pdf_x7i
            - copilots_header_6271a.file.ICD-10codesforSLPs.pdf_bFR
            - copilots_header_6271a.file.StrongSLPDocumentationPatterns.txt_xjA
            - copilots_header_6271a.file.7.LevelsofSupervisionforDysphagiaEvals.pdf_Siw
            - copilots_header_6271a.file.aota-apta-asha-consensus-statement.pdf_uWx

      knowledgeSources:
        kind: SearchSpecificKnowledgeSources
        knowledgeSources:
          - copilots_header_6271a.topic.httpswwwcmsgovoutreachandeducationmedicarelearningnetworkmln_wqEj5W3QWz7
          - copilots_header_6271a.topic.httpswwwashaorgslpclinical_OELZZf7AFpEWkm1BhulkJ

inputType: {}
outputType: {}
