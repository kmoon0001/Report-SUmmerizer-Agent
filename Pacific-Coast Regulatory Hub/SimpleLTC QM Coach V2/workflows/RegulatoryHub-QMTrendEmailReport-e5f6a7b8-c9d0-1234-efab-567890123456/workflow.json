{
  "properties": {
    "connectionReferences": {
      "shared_commondataserviceforapps": {
        "api": { "name": "shared_commondataserviceforapps" },
        "connection": { "connectionReferenceLogicalName": "new_sharedcommondataserviceforapps_af899" },
        "runtimeSource": "embedded"
      },
      "shared_office365": {
        "api": { "name": "shared_office365" },
        "connection": { "connectionReferenceLogicalName": "new_sharedoffice365_Pacific_Coast" },
        "runtimeSource": "embedded"
      }
    },
    "definition": {
      "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
      "contentVersion": "1.0.0.0",
      "description": "Pacific Coast Regulatory Hub — QM Trend Email Report Flow. Sends the longitudinal Facility QM Trend Report as a formatted HTML email to facility leadership. Grounded in CMS Five-Star Quality Rating methodology, QAPI requirements (42 CFR 483.75), and Microsoft Learn Power Automate email delivery best practices.",
      "parameters": {
        "$authentication": { "defaultValue": {}, "type": "SecureObject" },
        "$connections": { "defaultValue": {}, "type": "Object" }
      },
      "triggers": {
        "manual": {
          "type": "Request",
          "kind": "Skills",
          "inputs": {
            "schema": {
              "type": "object",
              "properties": {
                "text": {
                  "description": "The full facility QM trend analysis report content",
                  "title": "TrendReportContent",
                  "type": "string",
                  "x-ms-content-hint": "TEXT",
                  "x-ms-dynamically-added": true
                },
                "text_1": {
                  "description": "Facility name",
                  "title": "FacilityName",
                  "type": "string",
                  "x-ms-content-hint": "TEXT",
                  "x-ms-dynamically-added": true
                },
                "text_2": {
                  "description": "Report period (e.g., Q1 2026 vs Q4 2025)",
                  "title": "ReportPeriod",
                  "type": "string",
                  "x-ms-content-hint": "TEXT",
                  "x-ms-dynamically-added": true
                },
                "text_3": {
                  "description": "Recipient email addresses (comma-separated)",
                  "title": "RecipientEmails",
                  "type": "string",
                  "x-ms-content-hint": "TEXT",
                  "x-ms-dynamically-added": true
                }
              },
              "required": ["text", "text_1", "text_2", "text_3"]
            }
          },
          "metadata": {
            "operationMetadataId": "qm-trend-email-trigger-001",
            "flowSystemMetadata": { "flowKind": "Stateless" }
          }
        }
      },
      "actions": {
        "Send_QM_Trend_Report_Email": {
          "type": "OpenApiConnection",
          "inputs": {
            "parameters": {
              "emailMessage/To": "@triggerBody()?['text_3']",
              "emailMessage/Subject": "@{concat('[Pacific Coast QM Intelligence] Longitudinal Trend Report — ', triggerBody()?['text_1'], ' — ', triggerBody()?['text_2'])}",
              "emailMessage/Body": "@{concat('<h1 style=\"color:#2c5f8a\">📈 Pacific Coast Quality Measure Trend Report</h1><h2>', triggerBody()?['text_1'], ' | ', triggerBody()?['text_2'], '</h2><p><em>Generated by Pacific Coast Regulatory Hub AI | Grounded in CMS Five-Star Quality Rating System & QAPI (42 CFR 483.75)</em></p><hr/><div style=\"font-family:Arial;font-size:14px;white-space:pre-wrap\">', triggerBody()?['text'], '</div><hr/><h3>Distribution Notice</h3><p>This report is intended for: Administrator, Director of Nursing (DON), Director of Rehab (DOR), MDS Coordinator, and Medical Director.</p><p><strong>Action Required:</strong> Review all 🔴 HIGH RISK trends prior to the next QAPI meeting. Document interventions in your QAPI Performance Improvement Project (PIP) log.</p><p><em>Pacific Coast Therapy Hub AI — Regulatory Intelligence Engine. Data grounded in SimpleLTC QM methodology and CMS benchmark data.</em></p>')}"
            },
            "host": {
              "apiId": "/providers/Microsoft.PowerApps/apis/shared_office365",
              "operationId": "SendEmailV2",
              "connectionName": "shared_office365"
            }
          },
          "runAfter": {}
        },
        "Respond_to_the_agent": {
          "type": "Response",
          "kind": "Skills",
          "inputs": {
            "schema": {
              "type": "object",
              "properties": {
                "emailstatus": {
                  "title": "EmailStatus",
                  "description": "Email delivery confirmation",
                  "type": "string",
                  "x-ms-content-hint": "TEXT",
                  "x-ms-dynamically-added": true
                }
              },
              "additionalProperties": {}
            },
            "statusCode": 200,
            "body": {
              "emailstatus": "@{concat('QM Trend Report sent to: ', triggerBody()?['text_3'], ' at ', utcNow())}"
            }
          },
          "runAfter": { "Send_QM_Trend_Report_Email": ["SUCCEEDED"] },
          "metadata": { "operationMetadataId": "qm-trend-email-response-001" }
        }
      },
      "outputs": {}
    }
  },
  "schemaVersion": "1.0.0.0"
}
