mcs.metadata:
  componentName: Validate Documentation Completeness
  description: |
    Automated completeness validation topic.
    Uses AI to calculate completeness scores and risk levels based on clinical elements.
beginDialog:
  kind: OnRecognizedIntent
  id: main
  intent:
    triggerQueries:
      - validate documentation completeness
      - check if my documents are complete
      - is my paperwork complete
      - review my submitted documents
      - are all required documents included
      - verify document completeness
      - do I have all necessary documentation

  actions:
    - kind: SendActivity
      id: WelcomeMsg
      activity: I will now validate your documentation against CMS and discipline-specific compliance requirements.

    - kind: Question
      id: GetDiscipline
      variable: Topic.Discipline
      prompt: "Which discipline are we validating?"
      entity:
        kind: EmbeddedEntity
        definition:
          kind: ClosedListEntity
          optionSetName: DisciplineOptions
          items:
            - id: PT
              displayName: Physical Therapy
            - id: OT
              displayName: Occupational Therapy
            - id: SLP
              displayName: Speech-Language Pathology

    - kind: SendActivity
      id: AuditStatus
      activity: "ðŸ”„ **Running completeness audit...** checking for clinician signatures, objective baselines, and intervention clarity."

    - kind: BeginDialog
      id: CallComplianceEngine
      input:
        binding:
          mode: fact_check
      dialog: cr917_agentu92bPc.agent.Compliance_Risk_Engine
      output:
        binding:
          QuickRiskResult: Topic.AuditResult

    # Instead of asking for score, we parse it or display it directly.
    # Assuming Compliance_Risk_Engine returns a summary.

    - kind: SendActivity
      id: CompletenessSummary
      activity: |
        ### Documentation Completeness Summary
        {Topic.AuditResult}
        
        **Recommendations:**
        - Ensure all missing elements are addressed before submitting for final IDT review.

    - kind: Question
      id: NextStepChoice
      variable: Topic.NextAction
      prompt: "What would you like to do next?"
      entity:
        kind: EmbeddedEntity
        definition:
          kind: ClosedListEntity
          optionSetName: CompletenessNextSteps
          items:
            - id: human_review
              displayName: ðŸ•µï¸ Send to Human Review
            - id: edit_note
              displayName: ðŸ“ Revise Documentation
            - id: menu
              displayName: ðŸ  Back to Main Menu

    - kind: ConditionGroup
      id: ActionRedirect
      conditions:
        - id: GoHumanReview
          condition: =Topic.NextAction = CompletenessNextSteps.human_review
          actions:
            - kind: BeginDialog
              id: RunHumanReview
              dialog: cr917_agentu92bPc.topic.HumanReviewGate
        
        - id: GoMenu
          condition: =Topic.NextAction = CompletenessNextSteps.menu
          actions:
            - kind: BeginDialog
              id: RunMenu
              dialog: cr917_agentu92bPc.topic.Greeting

inputType: {}
outputType: {}

