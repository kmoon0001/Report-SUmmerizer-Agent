mcs.metadata:
  componentName: Greeting
  description: |
    Enhanced Greeting topic with a quick-start main menu (buttons) for improved UX.
beginDialog:
  kind: OnRecognizedIntent
  id: main
  intent:
    displayName: Greeting
    includeInOnSelectIntent: false
    triggerQueries:
      - Good afternoon
      - Good morning
      - Hello
      - Hey
      - Hi
      - start
      - get started
      - main menu

  actions:
    - kind: SendActivity
      id: IntroMsg
      activity: |
        Hello! I'm the **Pacific Coast Compliance Analyzer**. 
        
        I help rehab teams harden their documentation against audit risk. My feedback supports your clinical judgment by highlighting gaps in evidence, skilled need, and consistency.

    - kind: Question
      id: MainMenu
      variable: Topic.UserSelection
      prompt: "How can I assist you today?"
      entity:
        kind: EmbeddedEntity
        definition:
          kind: ClosedListEntity
          optionSetName: MainMenuOptions
          items:
            - id: classify
              displayName: ðŸ“‚ Classify & Route
            - id: extract
              displayName: ðŸ§¬ Extract Clinical Elements
            - id: skilled
              displayName: âš–ï¸ Check Skilled Need
            - id: goals
              displayName: ðŸŽ¯ Audit Goal Quality
            - id: redflag
              displayName: ðŸš© Red-Flag Prescreen

    - kind: ConditionGroup
      id: MenuRedirect
      conditions:
        - id: GoToClassify
          condition: =Topic.UserSelection = MainMenuOptions.classify
          actions:
            - kind: BeginDialog
              id: RunClassify
              dialog: cr917_agentu92bPc.topic.Classifyroutedocumentation
        
        - id: GoToExtract
          condition: =Topic.UserSelection = MainMenuOptions.extract
          actions:
            - kind: BeginDialog
              id: RunExtract
              dialog: cr917_agentu92bPc.topic.ExtractClincialElements

        - id: GoToSkilled
          condition: =Topic.UserSelection = MainMenuOptions.skilled
          actions:
            - kind: BeginDialog
              id: RunSkilled
              dialog: cr917_agentu92bPc.topic.SkilledNeedandMedicalNecessity

        - id: GoToGoals
          condition: =Topic.UserSelection = MainMenuOptions.goals
          actions:
            - kind: BeginDialog
              id: RunGoals
              dialog: cr917_agentu92bPc.topic.GoalsandProgressQuality

        - id: GoToRedFlag
          condition: =Topic.UserSelection = MainMenuOptions.redflag
          actions:
            - kind: BeginDialog
              id: RunRedFlag
              dialog: cr917_agentu92bPc.topic.Redflagprescreen

inputType: {}
outputType: {}

