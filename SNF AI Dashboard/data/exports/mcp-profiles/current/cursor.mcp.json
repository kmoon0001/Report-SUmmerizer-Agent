{
    "servers":  {
                    "pac-cli":  {
                                    "type":  "stdio",
                                    "command":  "pac",
                                    "args":  [
                                                 "copilot",
                                                 "mcp",
                                                 "--run"
                                             ]
                                },
                    "filesystem":  {
                                       "type":  "stdio",
                                       "command":  "npx",
                                       "args":  [
                                                    "-y",
                                                    "@modelcontextprotocol/server-filesystem",
                                                    "D:\\SNF AI Dashboard"
                                                ]
                                   },
                    "git":  {
                                "type":  "stdio",
                                "command":  "npx",
                                "args":  [
                                             "-y",
                                             "@modelcontextprotocol/server-git",
                                             "D:\\SNF AI Dashboard"
                                         ]
                            },
                    "github":  {
                                   "type":  "stdio",
                                   "command":  "npx",
                                   "args":  [
                                                "-y",
                                                "@modelcontextprotocol/server-github"
                                            ]
                               },
                    "learn-docs":  {
                                       "type":  "http",
                                       "url":  "https://learn.microsoft.com/api/mcp"
                                   },
                    "azure-mcp":  {
                                      "type":  "stdio",
                                      "command":  "npx",
                                      "args":  [
                                                   "-y",
                                                   "@azure/mcp@latest",
                                                   "server",
                                                   "start",
                                                   "--mode",
                                                   "consolidated"
                                               ]
                                  },
                    "powerbi-remote":  {
                                           "type":  "http",
                                           "url":  "https://api.fabric.microsoft.com/v1/mcp/powerbi"
                                       },
                    "playwright":  {
                                       "type":  "stdio",
                                       "command":  "npx",
                                       "args":  [
                                                    "-y",
                                                    "@playwright/mcp@latest",
                                                    "--headless",
                                                    "--output-dir",
                                                    "D:\\SNF AI Dashboard\\.playwright-mcp",
                                                    "--user-data-dir",
                                                    "D:\\SNF AI Dashboard\\.playwright-mcp\\profile",
                                                    "--save-session",
                                                    "--timeout-navigation",
                                                    "90000",
                                                    "--timeout-action",
                                                    "10000"
                                                ]
                                   }
                }
}
