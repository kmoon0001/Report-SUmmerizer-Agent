{
  "properties": {
    "definition": {
      "parameters": {
        "clinicalTeamsGroupId": {
          "type": "string",
          "defaultValue": ""
        },
        "nursingStationChannelId": {
          "type": "string",
          "defaultValue": ""
        }
      },
      "triggers": {
        "Recurrence": {
          "type": "Recurrence",
          "recurrence": {
            "frequency": "Week",
            "interval": 1,
            "schedule": {
              "weekDays": ["Friday"],
              "hours": ["16"],
              "minutes": ["0"]
            }
          }
        }
      },
      "actions": {
        "RetrieveShiftKPIs": {
          "type": "ApiConnection",
          "inputs": {
            "host": { "connection": { "name": "@json(decodeBase64(parameters('$connections'))).shared_commondataserviceforapps.connectionId" } },
            "method": "get",
            "path": "/v2/datasets/@{encodeURIComponent(encodeURIComponent('default'))}/tables/@{encodeURIComponent(encodeURIComponent('ShiftMetrics'))}/items"
          },
          "runAfter": {}
        },
        "PostShiftKickoffToTeams": {
          "type": "ApiConnection",
          "inputs": {
            "host": { "connection": { "name": "@json(decodeBase64(parameters('$connections'))).shared_teams.connectionId" } },
            "method": "post",
            "path": "/v2/teams/conversation/message/poster",
            "body": {
              "recipient": {
                "groupId": "@{parameters('clinicalTeamsGroupId')}",
                "channelId": "@{parameters('nursingStationChannelId')}"
              },
              "message": {
                "content": "<div style='background-color:#EFEFEF; padding:15px;'><h2>📈 FRIDAY DOR PULSE</h2><p><b>Generated:</b> @{utcNow()}</p><p><b>Summary:</b> Weekly compliance and revenue-at-risk snapshot prepared for DOR review.</p><p><b>Next Step:</b> Confirm high-risk items and assign owners for next week.</p></div>",
                "contentType": "html"
              }
            }
          },
          "runAfter": { "RetrieveShiftKPIs": ["Succeeded"] }
        }
      }
    }
  }
}
