{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite --host",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "node scripts/runWithEnv.mjs .env.example -- vitest run",
    "test:watch": "node scripts/runWithEnv.mjs .env.example -- vitest",
    "test:coverage": "node scripts/runWithEnv.mjs .env.example -- vitest run --coverage",
    "test:unit": "node scripts/runWithEnv.mjs .env.example -- vitest run src/test/unit",
    "test:integration": "node scripts/runWithEnv.mjs .env.example -- vitest run src/test/integration",
    "test:smoke": "node scripts/runWithEnv.mjs .env.example -- vitest run src/test/smoke",
    "test:e2e": "playwright test",
    "test:regression": "echo 'Visual regression tests would run here' && exit 0",
    "test:uat": "echo 'UAT automated scenarios would run here' && exit 0",
    "migration:preflight": "powershell -ExecutionPolicy Bypass -File ./scripts/Test-SlpMigrationPreflight.ps1",
    "spfx:preflight": "powershell -ExecutionPolicy Bypass -File ./scripts/Test-SpfxConversionPreflight.ps1",
    "migration:start": "powershell -ExecutionPolicy Bypass -File ./scripts/Start-SlpMigration.ps1",
    "migration:export-schema": "powershell -ExecutionPolicy Bypass -File ./scripts/Export-SlpListSchema.ps1",
    "migration:provision:playwright": "node ./scripts/provision-sharepoint-playwright.mjs",
    "migration:seed:playwright": "node ./scripts/seed-sharepoint-playwright.mjs",
    "migration:deploy:sharepoint": "node ./scripts/deploy-dist-to-sharepoint-playwright.mjs",
    "sharepoint:clinical-index": "node ./scripts/build-clinical-knowledge-index.mjs --sharepoint",
    "sharepoint:publish-source-index": "node ./scripts/build-clinical-knowledge-index.mjs --sharepoint && node ./scripts/publish-source-index-list.mjs",
    "sharepoint:bridge:dry-run": "node ./scripts/sharepoint-native-bridge.mjs",
    "sharepoint:bridge:validate": "node ./scripts/validate-sharepoint-native-bridge.mjs",
    "sharepoint:bridge:qa": "node ./scripts/sharepoint-bridge-qa.mjs",
    "sharepoint:bridge:qa:offline": "node ./scripts/sharepoint-bridge-qa.mjs --offline",
    "publish:sharepoint": "powershell -ExecutionPolicy Bypass -File ./scripts/Publish-SharePointPortal.ps1",
    "migration:checklist:status": "powershell -ExecutionPolicy Bypass -File ./scripts/Get-ChecklistStatus.ps1",
    "migration:checklist:run": "powershell -ExecutionPolicy Bypass -File ./scripts/Run-MigrationChecklist.ps1",
    "spfx:open-live": "node ./scripts/open-spfx-live-workbench.mjs",
    "spfx:verify-live": "node ./scripts/verify-spfx-live-workbench.mjs",
    "start": "vite preview"
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "@mlc-ai/web-llm": "^0.2.81",
    "@pnp/graph": "^4.19.0",
    "@pnp/logging": "^4.19.0",
    "@pnp/queryable": "^4.19.0",
    "@pnp/sp": "^4.19.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/node-cron": "^3.0.11",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^5.0.4",
    "@xenova/transformers": "^2.17.2",
    "axios": "^1.13.6",
    "better-sqlite3": "^12.4.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "eslint": "^10.0.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.1.0",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.5.207",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.7.0",
    "rss-parser": "^3.13.0",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@rollup/rollup-win32-x64-msvc": "^4.60.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.21",
    "jsdom": "^28.1.0",
    "lightningcss-win32-x64-msvc": "^1.32.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^0.19.8",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "node-domexception": "npm:empty-module@^0.0.2"
  }
}
