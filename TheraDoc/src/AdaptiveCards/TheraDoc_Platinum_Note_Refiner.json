{
  "type": "AdaptiveCard",
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "version": "1.4",
  "backgroundImage": {
    "url": "https://images.unsplash.com/photo-1576091160550-21735994b1a3?auto=format&fit=crop&q=80&w=1000",
    "fillMode": "cover"
  },
  "body": [
    {
      "type": "TextBlock",
      "text": "THERADOC | NOTE REFINEMENT",
      "color": "Accent",
      "weight": "Bolder",
      "size": "Small"
    },
    {
      "type": "TextBlock",
      "text": "Refine Generated Note Content",
      "weight": "Bolder",
      "size": "ExtraLarge",
      "wrap": true
    },
    {
      "type": "Input.Text",
      "id": "refinedNarrative",
      "label": "Narrative (AI Generated):",
      "isMultiline": true,
      "value": "${generativeNoteBody}",
      "placeholder": "Refine the narrative..."
    },
    {
      "type": "Input.ChoiceSet",
      "id": "complianceCheck",
      "label": "Self-Audit Check:",
      "choices": [
        { "title": "Skilled Intent clearly stated", "value": "skilled" },
        { "title": "Goal relationship documented", "value": "goal" }
      ],
      "isMultiSelect": true
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "💾 Save & Sign Note",
      "style": "positive",
      "data": { "actionType": "saveNote", "recordId": "${recordId}" }
    }
  ]
}
